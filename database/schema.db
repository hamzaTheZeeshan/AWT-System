CREATE DATABASE awtDb;
USE awtDb;

-- =========================
-- 1. Independent Tables
-- =========================

CREATE TABLE Users (
    user_id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(255),
    email VARCHAR(255) UNIQUE,
    password VARCHAR(255),
    phone VARCHAR(20),
    role VARCHAR(50)
);

CREATE TABLE Donation_Type (
    donation_type_id INT PRIMARY KEY,
    type_name VARCHAR(100)
);

CREATE TABLE Campaign (
    campaign_id INT PRIMARY KEY AUTO_INCREMENT,
    title VARCHAR(255),
    description TEXT,
    target_amount DECIMAL(15,2),
    amount_raised DECIMAL(15,2) DEFAULT 0,
    end_date DATE
);

CREATE TABLE Intern (
    intern_id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT NOT NULL,
    name VARCHAR(255),
    role VARCHAR(100),
    assigned_task TEXT,
    end_date DATE,
    status ENUM('pending', 'approved', 'rejected') DEFAULT 'pending',
    applied_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    rejected_reason TEXT,
    FOREIGN KEY (user_id) REFERENCES Users(user_id) ON DELETE CASCADE
);

CREATE TABLE Receiver (
    receiver_id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(255),
    location VARCHAR(255),
    contact_info VARCHAR(255),
    sufficiency ENUM('self_sufficient', 'not_self_sufficient') DEFAULT 'not_self_sufficient',
    needs_description TEXT,
    priority ENUM('high', 'medium', 'low') DEFAULT 'medium'
);

CREATE TABLE Orphanage (
    orphanage_id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(255) NOT NULL,
    location VARCHAR(255),
    contact_info VARCHAR(255)
);

-- =========================
-- 2. Dependent Tables
-- =========================

CREATE TABLE Donation (
    donation_id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT,
    campaign_id INT,
    donation_type_id INT,
    orphanage_id INT,
    date DATE,
    amount DECIMAL(15,2),
    status VARCHAR(50),

    FOREIGN KEY (user_id) REFERENCES Users(user_id),
    FOREIGN KEY (campaign_id) REFERENCES Campaign(campaign_id),
    FOREIGN KEY (donation_type_id) REFERENCES Donation_Type(donation_type_id),
    FOREIGN KEY (orphanage_id) REFERENCES Orphanage(orphanage_id)
);

CREATE TABLE Clothes (
    cloth_id INT PRIMARY KEY AUTO_INCREMENT,
    donation_id INT,
    type VARCHAR(100),
    size VARCHAR(50),
    conditionOfCloth VARCHAR(100),
    description TEXT,
    quantity INT,

    FOREIGN KEY (donation_id) REFERENCES Donation(donation_id)
);

CREATE TABLE Books (
    book_id INT PRIMARY KEY AUTO_INCREMENT,
    donation_id INT,
    title VARCHAR(255),
    author VARCHAR(100),
    conditionOfBook VARCHAR(100),
    description TEXT,
    quantity INT,

    FOREIGN KEY (donation_id) REFERENCES Donation(donation_id)
);


CREATE TABLE Distribution (
    distribution_id INT PRIMARY KEY AUTO_INCREMENT,
    donation_id INT,
    receiver_id INT,
    orphanage_id INT,
    date DATE,
    quantity INT,

    FOREIGN KEY (donation_id) REFERENCES Donation(donation_id),
    FOREIGN KEY (receiver_id) REFERENCES Receiver(receiver_id),
    FOREIGN KEY (orphanage_id) REFERENCES Orphanage(orphanage_id)
);

-- =========================
-- 3. Insert Default Donation Types
-- =========================

