create database awtDb;
use awtDb;


-- 1. Create independent tables first
CREATE TABLE Users (
    user_id INT PRIMARY KEY,
    name VARCHAR(255),
    email VARCHAR(255) UNIQUE,
    password VARCHAR(255),
    phone VARCHAR(20),
    role VARCHAR(50)
);

CREATE TABLE Donation_Type (
    donation_type_id INT PRIMARY KEY,
    type_name VARCHAR(100)
);

CREATE TABLE Campaign (
    campaign_id INT PRIMARY KEY,
    title VARCHAR(255),
    description TEXT,
    target_amount DECIMAL(15, 2),
    end_date DATE
);

CREATE TABLE Intern (
    intern_id INT PRIMARY KEY,
    name VARCHAR(255),
    role VARCHAR(100),
    assigned_task TEXT,
    end_date DATE
);

CREATE TABLE Reciever (
    receiver_id INT PRIMARY KEY,
    name VARCHAR(255),
    location VARCHAR(255),
    contact_info VARCHAR(255)
);

-- 2. Create tables with dependencies (Foreign Keys)
CREATE TABLE Donation (
    donation_id INT PRIMARY KEY,
    user_id INT,
    campaign_id INT,
    donation_type_id INT,
    date DATE,
    amount DECIMAL(15, 2),
    status VARCHAR(50),
    FOREIGN KEY (user_id) REFERENCES Users(user_id),
    FOREIGN KEY (campaign_id) REFERENCES Campaign(campaign_id),
    FOREIGN KEY (donation_type_id) REFERENCES Donation_Type(donation_type_id)
);

-- 3. Create specialized/sub-type tables
CREATE TABLE Clothes (
    cloth_id INT PRIMARY KEY,
    donation_id INT,
    type VARCHAR(100),
    size VARCHAR(50),
    conditionOfCloth VARCHAR(100),
	description TEXT,
    quantity INT,
    FOREIGN KEY (donation_id) REFERENCES Donation(donation_id)
);



CREATE TABLE Books (
    book_id INT PRIMARY KEY,
    donation_id INT,
    title VARCHAR(255),
    author VARCHAR(100),
    conditionOfBook VARCHAR(100),
	description TEXT,
    quantity INT,
    FOREIGN KEY (donation_id) REFERENCES Donation(donation_id)
);
CREATE TABLE Orphanage (
    receiver_id INT PRIMARY KEY,
    name VARCHAR(255),
    location VARCHAR(255),
    contact_info VARCHAR(255),
    FOREIGN KEY (receiver_id) REFERENCES Reciever(receiver_id)
);

CREATE TABLE Distribution (
    distribution_id INT PRIMARY KEY,
    donation_id INT,
    receiver_id INT,
    date DATE,
    quantity INT,
    FOREIGN KEY (donation_id) REFERENCES Donation(donation_id),
    FOREIGN KEY (receiver_id) REFERENCES Reciever(receiver_id)
);


insert into Donation_Type (donation_type_id, type_name)
values (1, "Money"),
(2, "Zakat"),
 (3, "Sadqah"),
