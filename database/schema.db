(5, "Books");

ALTER TABLE Campaign ADD COLUMN amount_raised DECIMAL(15,2) DEFAULT 0;
ALTER TABLE Donation ADD COLUMN receiver_id INT;
ALTER TABLE Donation ADD FOREIGN KEY (receiver_id) REFERENCES Reciever(receiver_id);

ALTER TABLE Reciever ADD COLUMN sufficiency ENUM('self_sufficient', 'not_self_sufficient') DEFAULT 'not_self_sufficient';

ALTER TABLE Reciever 
ADD COLUMN needs_description TEXT,
ADD COLUMN priority ENUM('high', 'medium', 'low') DEFAULT 'medium';


select * from campaign;

----------new changes --------------------------------------------------------

-- 2. Drop the old Orphanage table
DROP TABLE IF EXISTS Orphanage;

-- 3. Create new Orphanage table with independent primary key
CREATE TABLE Orphanage (
    orphanage_id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(255) NOT NULL,
    location VARCHAR(255),
    contact_info VARCHAR(255)
);

-- 4. Add orphanage_id to Donation (if not already present)
ALTER TABLE Donation ADD COLUMN orphanage_id INT;
ALTER TABLE Donation ADD FOREIGN KEY (orphanage_id) REFERENCES Orphanage(orphanage_id);

-- 5. Add orphanage_id to Distribution (if not already present)
ALTER TABLE Distribution ADD COLUMN orphanage_id INT;
ALTER TABLE Distribution ADD FOREIGN KEY (orphanage_id) REFERENCES Orphanage(orphanage_id);


ALTER TABLE Donation DROP FOREIGN KEY donation_ibfk_4;
ALTER TABLE Donation DROP COLUMN receiver_id;